# ─── Domain ────────────────────────────────────────────────────────────────
DOMAIN=farmiot.devinbutts.net

# ─── Cloudflare Tunnel ─────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ─── PostgreSQL (bootstrap only — Vault issues dynamic creds to services) ──
# These are only used to initialize the DB and seed the Vault DB engine.
# Services never receive these — they get short-lived dynamic creds from Vault.
POSTGRES_USER=farmsense
POSTGRES_PASSWORD=changeme
POSTGRES_DB=farmsense

# ─── InfluxDB (bootstrap only — token is stored in Vault KV after init) ────
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=changeme
INFLUXDB_ORG=farmsense
INFLUXDB_BUCKET=sensors
# Generate with: openssl rand -hex 32
INFLUXDB_ADMIN_TOKEN=changeme

# ─── Kafka ─────────────────────────────────────────────────────────────────
KAFKA_SENSOR_TOPIC=farm.sensors

# ─── Vault AppRole credentials (output by infra/vault/init.sh) ─────────────
# Scoped, low-privilege credentials — NOT the root token.
# Run init.sh once; it prints these values for you to paste here.
VAULT_API_ROLE_ID=
VAULT_API_SECRET_ID=
VAULT_CONSUMER_ROLE_ID=
VAULT_CONSUMER_SECRET_ID=
